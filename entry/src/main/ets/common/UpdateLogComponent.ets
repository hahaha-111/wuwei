@Component
export struct UpdateLogPopup {
  // Receive screen state
  @Prop isPhone: boolean = true;
  // Close callback
  onClose: () => void = () => {};

  build() {
    Column() {
      // Title Bar
      Row() {
        Text('更新日志')
          .fontSize(18)
          .fontWeight(FontWeight.Bold)
          .fontColor('#333333')
        Blank()
        Text('✕')
          .fontSize(20)
          .fontColor('#999999')
          .onClick(() => {
            if (this.onClose) {
              this.onClose();
            }
          })
      }
      .width('100%')
      .padding({ bottom: 12 })
      .border({ width: { bottom: 1 }, color: '#EEEEEE' })

      // Log List
      List() {
        ForEach(UPDATE_LOGS, (item: UpdateLogItem) => {
          ListItem() {
            Column({ space: 6 }) {
              Row() {
                Text(item.version)
                  .fontSize(16)
                  .fontWeight(FontWeight.Bold)
                  .fontColor('#E53935') // Red emphasis
                Blank()
                Text(item.date)
                  .fontSize(12)
                  .fontColor('#999999')
              }
              .width('100%')

              Column({ space: 6 }) {
                ForEach(item.content, (line: string) => {
                  Row() {
                    Text('•')
                      .margin({ right: 6 })
                      .fontColor('#666666')
                      .lineHeight(20)
                    Text(line)
                      .fontSize(14)
                      .fontColor('#333333')
                      .layoutWeight(1)
                      .lineHeight(20)
                  }
                  .alignItems(VerticalAlign.Top)
                  .width('100%')
                })
              }
              .width('100%')
            }
            .padding({ top: 12, bottom: 12 })
            .width('100%')
          }
        })
      }
      .layoutWeight(1)
      .width('100%')
      .height('100%')
      .divider({ strokeWidth: 1, color: '#F5F5F5', startMargin: 0, endMargin: 0 })

      Button('关闭')
        .width('100%')
        .height(40)
        .margin({ top: 12 })
        .backgroundColor('#E53935')
        .fontColor(Color.White)
        .onClick(() => {
          if (this.onClose) {
            this.onClose();
          }
        })
    }
    .width(this.isPhone ? '90%' : '400vp')
    .height(this.isPhone ? '70%' : '600vp')
    .backgroundColor(Color.White)
    .borderRadius(12)
    .padding(16)
    .shadow({ radius: 16, color: '#40000000', offsetY: 4 })
    // Prevent event bubbling
    .onClick(() => {})
  }
}